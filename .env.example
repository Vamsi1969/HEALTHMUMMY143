# OpenRouter API Configuration
# Get your API key from: https://openrouter.ai/keys
# OpenRouter supports many models: Gemini, GPT, Claude, Llama, etc.
OPENROUTER_API_KEY=
# Model to use. Free options include:
# - google/gemma-4-31b-it:free  (recommended — best safety + speed)
# - nvidia/nemotron-3-super-120b-a12b:free  (larger, deeper reasoning)
# - meta-llama/llama-3.3-70b-instruct:free
OPENROUTER_MODEL=google/gemma-4-31b-it:free

# Google OAuth Client ID for Sign-In
# Get one from: https://console.cloud.google.com/apis/credentials
# 1. Create a new project or select existing
# 2. Go to APIs & Services > Credentials
# 3. Create OAuth client ID > Web application
# 4. Add 'http://localhost:8080' to Authorized JavaScript origins
# 5. Add 'http://localhost:8080' to Authorized redirect URIs
# 6. Copy the Client ID here
GOOGLE_CLIENT_ID=
